<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Contacto - Sofia G.</title>
    <style>
        /* Estilo general del cuerpo */
        body {
            font-family: Arial, sans-serif;
            background-color: #0A1030;
            color: #520C24;
            margin: 0;
            padding: 20px 0;
        
        }


        /* Contenedor principal */
        .contenedor {
            width: 60%;
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;       /* Centra los bloques horizontalmente */
        }
        .bloque {
            background-color: #ffffff; /* Guinda */
            margin: 15px 0;
            padding: 30px;
            border-radius: 10px;
            width: 100%;
            text-align: left;
            
         }      

            /* 2. LOS BOTONES PEQUEÑOS (Obras y Contacto) */
        .interactivo {
            background-color: #520C24;
            margin: 10px 0;
            padding: 15px 30px;
            border-radius: 8px;
            transition: 0.3s;
            cursor: pointer;  
            width: fit-content
            text-align: center;
            
        }
        
        .interactivo:hover {
            background-color: #8b1919; /* Brilla al pasar el mouse */
            transform: scale(1.1);     /* Crece un poquito */
        
            
        }

        /* Sección o bloque */
        .interactivo a {
            color: #ffffff;
            text-decoration: none;
            font-size: 18px;
            font-weight: bold;
        }

    


        /* Imagen */
        .bloque img {
            width: 250px;
            height: 300px;
            object-fit: cover;         /* No se deforma */
            border-radius: 10px;
        
        }

        .bloque h2 { margin-top: 15px; }
        .bloque p { line-height: 1.5; }
    </style>
</head>

<body>

   <div class="contenedor">

        <div class="bloque">
            <img src="img/IMG_3095.jpeg" alt="Descripción de la imagen">
            <h2>"Costado"</h2>
            <p>Monotipo. Parte de la serie "Dientes"</p>
        </div>

        <div class="interactivo">
            <a href="pagina1.html">Obras</a>
        </div> 

        <div class="interactivo">
            <a href="index.html">Inicio</a>
        </div>

    </div>

</body>
</html>
